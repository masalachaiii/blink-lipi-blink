{
    "manifest_version": 3,
    "name": "BLINK LIPI BLINK!",
    "description": "Extension to blink every 20 minutes for 20 seconds.",
    "version": "1.0",

    "permissions": [
        "alarms",
        "notifications"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_popup": "blink.html"
    },

    "icons": {
        "16": "icons/blink16.png",
        "48": "icons/blink48.png",
        "128": "icons/blink128.png"
    }
}